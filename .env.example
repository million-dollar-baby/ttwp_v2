# ─── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── WordPress Site ───────────────────────────────────────────
WP_URL=https://yoursite.com
WP_USER=admin
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx   # WP Application Password

# ─── SSH / Server ─────────────────────────────────────────────
SSH_HOST=yourserver.com
SSH_PORT=22
SSH_USER=ubuntu
SSH_KEY_PATH=/home/you/.ssh/id_rsa
WP_PATH=/var/www/html                            # Absolute path on server

# ─── Staging (optional but strongly recommended) ──────────────
STAGING_URL=https://staging.yoursite.com
STAGING_SSH_HOST=staging.yourserver.com
STAGING_WP_PATH=/var/www/staging

# ─── Database (for direct query tools) ───────────────────────
DB_HOST=localhost
DB_NAME=wordpress
DB_USER=wp_user
DB_PASSWORD=yourpassword

# ─── Git (optional – enables rollback) ───────────────────────
GIT_REPO=git@github.com:you/yoursite.git
GIT_BRANCH=main

# ─── Notifications (optional) ────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
NOTIFY_EMAIL_TO=you@example.com
NOTIFY_EMAIL_FROM=wp-agent@yoursite.com
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@yoursite.com
SMTP_PASS=yourpassword
# Public URL for dashboard links in notifications
DASHBOARD_URL=https://your-agent.example.com

# ─── Agent behaviour ─────────────────────────────────────────
# Require human approval for high-risk actions (true/false)
REQUIRE_APPROVAL=true
# Port for the web dashboard
DASHBOARD_PORT=3000
# Log level: error | warn | info | debug
LOG_LEVEL=info
